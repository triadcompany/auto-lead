generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum AppRole {
  admin
  seller

  @@map("app_role")
}

enum TaskPriority {
  baixa
  media
  alta

  @@map("task_priority")
}

enum TaskStatus {
  pendente
  em_andamento
  concluida
  atrasada

  @@map("task_status")
}

enum FollowupStatus {
  PENDENTE
  ENVIADO
  PULADO
  FALHOU
  CANCELADO

  @@map("followup_status")
}

enum FollowupSentBy {
  AUTO
  MANUAL

  @@map("followup_sent_by")
}

enum MessageDirection {
  outbound
  inbound

  @@map("message_direction")
}

enum MessageChannel {
  whatsapp
  email
  sms

  @@map("message_channel")
}

// ─── CLERK AUTH TABLES ────────────────────────────────────────────────────────

/// Mirror of Clerk organization (synced via webhook)
model ClerkOrganization {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkOrgId  String    @unique @map("clerk_org_id")
  name        String
  slug        String?
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  orgMembers OrgMember[]

  @@map("clerk_organizations")
}

/// Clerk org membership (synced via webhook)
model OrgMember {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  clerkOrgId     String           @map("clerk_org_id")
  clerkUserId    String           @map("clerk_user_id")
  role           String           // 'admin' | 'seller' | 'pre_sales'
  status         String?          @default("active")
  orgId          String?          @map("org_id")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @default(now()) @map("updated_at") @db.Timestamptz

  organization ClerkOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, clerkUserId])
  @@unique([clerkOrgId, clerkUserId])
  @@map("org_members")
}

/// Clerk user profile mirror (synced via webhook)
model UsersProfile {
  clerkUserId String   @id @map("clerk_user_id")
  email       String?
  fullName    String?  @map("full_name")
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("users_profile")
}

// ─── CORE ─────────────────────────────────────────────────────────────────────

model Organization {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkOrgId                String?   @unique @map("clerk_org_id")
  name                      String
  cnpj                      String?   @unique
  phone                     String?
  email                     String?
  address                   String?
  city                      String?
  state                     String?
  zipCode                   String?   @map("zip_code")
  isActive                  Boolean   @default(true) @map("is_active")
  ownerProfileId            String?   @map("owner_profile_id") @db.Uuid
  logoUrl                   String?   @map("logo_url")
  aiSystemPrompt            String?   @map("ai_system_prompt")
  aiAutoReplyThrottleSeconds Int      @default(20) @map("ai_auto_reply_throttle_seconds")
  aiAutoMaxWithoutReply     Int       @default(2) @map("ai_auto_max_without_reply")
  aiAutoDebounceSeconds     Int       @default(4) @map("ai_auto_debounce_seconds")
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  ownerProfile              Profile?  @relation("OrgOwner", fields: [ownerProfileId], references: [id], onDelete: SetNull)

  profiles                  Profile[]  @relation("ProfileOrg")
  pipelines                 Pipeline[]
  leads                     Lead[]
  leadSources               LeadSource[]
  tasks                     Task[]
  vehicles                  Vehicle[]
  whatsappIntegrations      WhatsappIntegration[]
  conversations             Conversation[]
  messages                  Message[]
  followupTemplates         FollowupTemplate[]
  followupCadences          FollowupCadence[]
  followups                 Followup[]
  messageLogs               MessageLog[]
  whatsappConfig            WhatsappConfig[]
  automations               Automation[]
  automationFlows           AutomationFlow[]
  automationRuns            AutomationRun[]
  automationJobs            AutomationJob[]
  automationLogs            AutomationLog[]
  automationEvents          AutomationEvent[]
  automationKeywordRules    AutomationKeywordRule[]
  organizationAutomationSettings OrganizationAutomationSettings?
  whatsappFirstTouch        WhatsappFirstTouch[]
  whatsappRoutingSettings   WhatsappRoutingSettings[]
  whatsappRoutingState      WhatsappRoutingState[]
  whatsappRoutingBucketSettings WhatsappRoutingBucketSettings[]
  whatsappThreads           WhatsappThread[]
  whatsappMessages          WhatsappMessage[]
  opportunities             Opportunity[]
  metaCapiEvents            MetaCapiEvent[]
  metaCapiSettings          MetaCapiSettings[]
  metaCapiMappings          MetaCapiMapping[]
  metaCapiLogs              MetaCapiLog[]
  capiEventDefinitions      CapiEventDefinition[]
  metaIntegrations          MetaIntegration[]
  metaAccounts              MetaAccount[]
  aiAgentProfiles           AiAgentProfile[]
  socialIntegrations        SocialIntegration[]
  conversationEvents        ConversationEvent[]
  conversationNotes         ConversationNote[]
  instagramConnections      InstagramConnection[]
  instagramConversations    InstagramConversation[]
  instagramQuickReplies     InstagramQuickReply[]
  instagramConversationTags InstagramConversationTag[]
  instagramMetrics          InstagramMetrics[]
  instagramDistributionConfig InstagramDistributionConfig[]
  instagramDistributionState  InstagramDistributionState[]
  leadDistributionSettings  LeadDistributionSettings[]
  aiAutoReplyJobs           AiAutoReplyJob[]
  automationExecutions      AutomationExecution[]
  automationFirstContacts   AutomationFirstContact[]
  distributionSchedules     DistributionSchedule[]

  @@map("organizations")
}

model Profile {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String?   @unique @map("user_id") @db.Uuid   // legacy Supabase auth
  clerkUserId          String?   @unique @map("clerk_user_id")
  name                 String
  email                String
  role                 AppRole   @default(seller)
  organizationId       String?   @map("organization_id") @db.Uuid
  avatarUrl            String?   @map("avatar_url")
  whatsappE164         String?   @map("whatsapp_e164")
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization    Organization?  @relation("ProfileOrg", fields: [organizationId], references: [id])
  ownedOrgs       Organization[] @relation("OrgOwner")

  createdLeads         Lead[]         @relation("LeadCreator")
  assignedLeads        Lead[]         @relation("LeadSeller")
  createdPipelines     Pipeline[]     @relation("PipelineCreator")
  createdStages        PipelineStage[] @relation("StageCreator")
  tasks                Task[]         @relation("TaskAssignee")
  createdTasks         Task[]         @relation("TaskCreator")
  vehicles             Vehicle[]      @relation("VehicleCreator")
  assignedConversations Conversation[] @relation("ConvAssignee")
  lockedConversations  Conversation[] @relation("ConvLocker")
  conversationNotes    ConversationNote[]
  pipelinePermissions  PipelinePermission[] @relation("ProfilePermissions")
  createdPermissions   PipelinePermission[] @relation("PermCreator")
  appliedAiStageActions AiStageAction[]  @relation("AppliedBy")
  assignedOpportunities Opportunity[]   @relation("OppAssignee")
  metaIntegrations     MetaIntegration[] @relation("SellerMeta")
  fromTransfers        ConversationTransfer[] @relation("TransferFrom")
  toTransfers          ConversationTransfer[] @relation("TransferTo")
  conversationEvents   ConversationEvent[] @relation("EventPerformer")

  @@map("profiles")
}

// ─── USER ROLES (legacy) ─────────────────────────────────────────────────────

model UserRole {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  clerkUserId    String?   @map("clerk_user_id")
  role           AppRole
  organizationId String    @map("organization_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@map("user_roles")
}

model UserInvitation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  email          String
  name           String
  role           AppRole   @default(seller)
  status         String    @default("pending")
  invitedBy      String?   @map("invited_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@map("user_invitations")
}

// ─── CRM CORE ─────────────────────────────────────────────────────────────────

model Pipeline {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  description    String?
  isDefault      Boolean   @default(false) @map("is_default")
  isActive       Boolean   @default(true) @map("is_active")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization Organization  @relation(fields: [organizationId], references: [id])
  creator      Profile?      @relation("PipelineCreator", fields: [createdBy], references: [id])
  stages       PipelineStage[]
  leads        Lead[]
  opportunities Opportunity[]
  permissions  PipelinePermission[]
  metaIntegrations MetaIntegration[] @relation("PipelineMeta")

  @@map("pipelines")
}

model PipelineStage {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipelineId  String    @map("pipeline_id") @db.Uuid
  name        String
  position    Int
  color       String    @default("#3B82F6")
  isActive    Boolean   @default(true) @map("is_active")
  sensitive   Boolean   @default(false)
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id])
  creator     Profile?  @relation("StageCreator", fields: [createdBy], references: [id])
  leads       Lead[]
  opportunities Opportunity[]
  metaIntegrations MetaIntegration[] @relation("StageMeta")

  @@map("pipeline_stages")
}

model PipelinePermission {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipelineId String    @map("pipeline_id") @db.Uuid
  profileId  String    @map("profile_id") @db.Uuid
  createdBy  String?   @map("created_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  pipeline   Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  profile    Profile   @relation("ProfilePermissions", fields: [profileId], references: [id], onDelete: Cascade)
  creator    Profile?  @relation("PermCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([pipelineId, profileId])
  @@map("pipeline_permissions")
}

model LeadSource {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  isActive       Boolean   @default(true) @map("is_active")
  sortOrder      Int       @default(0) @map("sort_order")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime? @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  leads        Lead[]

  @@map("lead_sources")
}

model Lead {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String    @map("organization_id") @db.Uuid
  name                 String
  phone                String
  email                String?
  sellerId             String?   @map("seller_id") @db.Uuid
  source               String?
  leadSource           String?   @map("lead_source")
  leadSourceId         String?   @map("lead_source_id") @db.Uuid
  interest             String?
  observations         String?
  stageId              String?   @map("stage_id") @db.Uuid
  pipelineId           String?   @map("pipeline_id") @db.Uuid
  servico              String?
  cidade               String?
  estado               String?
  fbc                  String?
  fbp                  String?
  metaCampaignId       String?   @map("meta_campaign_id")
  metaCampaignName     String?   @map("meta_campaign_name")
  metaAdsetId          String?   @map("meta_adset_id")
  metaAdsetName        String?   @map("meta_adset_name")
  metaAdId             String?   @map("meta_ad_id")
  metaAdName           String?   @map("meta_ad_name")
  valorNegocio         Float?    @map("valor_negocio")
  lastReplyAt          DateTime? @map("last_reply_at") @db.Timestamptz
  lastInboundMessageAt DateTime? @map("last_inbound_message_at") @db.Timestamptz
  lastInboundMessageText String? @map("last_inbound_message_text")
  tags                 String[]  @default([])
  createdBy            String?   @map("created_by") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id])
  seller        Profile?      @relation("LeadSeller", fields: [sellerId], references: [id])
  creator       Profile?      @relation("LeadCreator", fields: [createdBy], references: [id])
  stage         PipelineStage? @relation(fields: [stageId], references: [id])
  pipeline      Pipeline?     @relation(fields: [pipelineId], references: [id])
  leadSourceRef LeadSource?   @relation(fields: [leadSourceId], references: [id])

  tasks         Task[]
  followups     Followup[]
  messageLogs   MessageLog[]
  whatsappMessages WhatsappMessage[]
  conversations Conversation[]
  opportunities Opportunity[] @relation("OpportunityLead")
  metaCapiEvents MetaCapiEvent[]
  aiStageActions AiStageAction[]

  leadInboxes         LeadInbox[]         @relation("LeadInboxLead")
  leadAssignments     LeadAssignment[]    @relation("LeadAssignmentLead")
  automationRuns      AutomationRun[]     @relation("AutomationRunLead")

  @@map("leads")
}

model Task {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String      @map("organization_id") @db.Uuid
  leadId          String      @map("lead_id") @db.Uuid
  conversationId  String?     @map("conversation_id") @db.Uuid
  assignedTo      String?     @map("assigned_to") @db.Uuid
  titulo          String
  descricao       String?
  priority        TaskPriority @default(media)
  status          TaskStatus  @default(pendente)
  dueDate         DateTime?   @map("due_date") @db.Timestamptz
  createdBy       String?     @map("created_by") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @default(now()) @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id])
  lead          Lead          @relation(fields: [leadId], references: [id])
  conversation  Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  assignee      Profile?      @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator       Profile?      @relation("TaskCreator", fields: [createdBy], references: [id])

  @@map("tasks")
}

model Vehicle {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  brand          String
  model          String
  year           Int
  fuelType       String?   @map("fuel_type")
  transmission   String?
  mileage        Int?
  color          String?
  price          Decimal?  @db.Decimal
  status         String    @default("available")
  description    String?
  images         String[]
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization  Organization @relation(fields: [organizationId], references: [id])
  creator       Profile      @relation("VehicleCreator", fields: [createdBy], references: [id])

  @@map("vehicles")
}

model Prospect {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  phone          String?
  email          String?
  source         String?
  notes          String?
  status         String    @default("new")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@map("prospects")
}

model Opportunity {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  leadId         String?   @map("lead_id") @db.Uuid
  pipelineId     String?   @map("pipeline_id") @db.Uuid
  stageId        String?   @map("stage_id") @db.Uuid
  priority       String?
  assignedTo     String?   @map("assigned_to") @db.Uuid
  source         String?
  sourceDetail   String?   @map("source_detail")
  status         String?
  value          Decimal?  @db.Decimal
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization  Organization  @relation(fields: [organizationId], references: [id])
  lead          Lead?         @relation("OpportunityLead", fields: [leadId], references: [id])
  pipeline      Pipeline?     @relation(fields: [pipelineId], references: [id])
  stage         PipelineStage? @relation(fields: [stageId], references: [id])
  assignee      Profile?      @relation("OppAssignee", fields: [assignedTo], references: [id])

  @@map("opportunities")
}

// ─── LEAD DISTRIBUTION ────────────────────────────────────────────────────────

model LeadDistributionSettings {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String    @unique @map("organization_id") @db.Uuid
  isAutoDistributionEnabled Boolean   @default(false) @map("is_auto_distribution_enabled")
  distributionType          String    @default("round_robin") @map("distribution_type")
  mode                      String    @default("manual")
  manualReceiverId          String?   @map("manual_receiver_id") @db.Uuid
  rrCursor                  Int       @default(0) @map("rr_cursor")
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization  Organization @relation(fields: [organizationId], references: [id])
  users         LeadDistributionUser[]
  rules         LeadDistributionRule[]
  state         LeadDistributionState[]

  @@map("lead_distribution_settings")
}

model LeadDistributionUser {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributionSettingId  String    @map("distribution_setting_id") @db.Uuid
  userId                 String    @map("user_id") @db.Uuid
  orderPosition          Int       @default(0) @map("order_position")
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz

  distributionSetting LeadDistributionSettings @relation(fields: [distributionSettingId], references: [id])

  @@map("lead_distribution_users")
}

model LeadDistributionRule {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributionSettingId  String    @map("distribution_setting_id") @db.Uuid
  name                   String
  conditions             Json      @default("{}")
  actions                Json      @default("{}")
  priority               Int       @default(0)
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  distributionSetting LeadDistributionSettings @relation(fields: [distributionSettingId], references: [id])

  @@map("lead_distribution_rules")
}

model LeadDistributionState {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributionSettingId  String    @unique @map("distribution_setting_id") @db.Uuid
  lastAssignedUserId     String?   @map("last_assigned_user_id") @db.Uuid
  lastAssignmentAt       DateTime? @map("last_assignment_at") @db.Timestamptz
  assignmentCount        Int       @default(0) @map("assignment_count")
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  distributionSetting LeadDistributionSettings @relation(fields: [distributionSettingId], references: [id])

  @@map("lead_distribution_state")
}

model LeadDistributionAudit {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event     String
  data      Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("lead_distribution_audit")
}

model LeadInbox {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId String    @unique @map("external_id")
  payload    Json?
  leadId     String?   @map("lead_id") @db.Uuid
  status     String    @default("novo")
  receivedAt DateTime  @default(now()) @map("received_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  lead Lead? @relation("LeadInboxLead", fields: [leadId], references: [id])

  @@map("lead_inbox")
}

model LeadAssignment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId         String   @unique @map("lead_id") @db.Uuid
  assignedUserId String   @map("assigned_user_id") @db.Uuid
  assignedAt     DateTime @default(now()) @map("assigned_at") @db.Timestamptz

  lead Lead @relation("LeadAssignmentLead", fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_assignment")
}

model DistributionSchedule {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  bucket          String    // 'traffic' | 'non_traffic' | 'all'
  name            String
  daysOfWeek      Int[]     @map("days_of_week")
  startTime       String    @map("start_time")
  endTime         String    @map("end_time")
  assignedUserIds String[]  @map("assigned_user_ids")
  isActive        Boolean   @default(true) @map("is_active")
  priority        Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("distribution_schedules")
}

// ─── FOLLOW-UP / CADENCE ──────────────────────────────────────────────────────

model FollowupTemplate {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  category       String    @default("geral")
  content        String
  variables      String[]  @default([])
  isActive       Boolean   @default(true) @map("is_active")
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  followups    Followup[]

  @@map("followup_templates")
}

model FollowupCadence {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  description    String?
  steps          Json      @default("[]")
  isDefault      Boolean   @default(false) @map("is_default")
